{
  "name": "3point-game-nhl-standing",
  "version": "0.1.0",
  "description": "--- ## About this Project",
  "scripts": {
    "clean": "npx gatsby clean; rm -rf dist .nyc_output",
    "fetch": "npm run clean; tsc; node dist/fetch.js",
    "cfetch": "clear; npm run fetch",
    "test": "npx jest --verbose",
    "test2": "mocha --recursive -r ts-node/register test/unit/**/*.ts test/unit/**/**/*.ts",
    "coverage": "nyc npm run test",
    "lint": "eslint './{src,test}/**/*.ts'",
    "build": "npx gatsby build",
    "develop": "npx gatsby develop",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "start": "npm run develop",
    "serve": "npx gatsby serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romdj/3point-game-nhl-standing.git"
  },
  "keywords": [
    "NHL®",
    "IIHF®",
    "Hockey"
  ],
  "author": "romdj",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/romdj/3point-game-nhl-standing/issues"
  },
  "homepage": "https://github.com/romdj/3point-game-nhl-standing#readme",
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.1",
    "@types/chai": "^4.2.9",
    "@types/express": "^4.17.3",
    "@types/jest": "^25.2.1",
    "@types/mocha": "^7.0.1",
    "@types/node": "^13.13.0",
    "@types/request-promise-native": "^1.0.17",
    "@typescript-eslint/eslint-plugin": "^2.28.0",
    "@typescript-eslint/parser": "^2.28.0",
    "chai": "^4.2.0",
    "eslint": "^6.8.0",
    "express": "^4.17.1",
    "jest": "^25.2.4",
    "mocha": "^7.0.1",
    "nyc": "^15.0.1",
    "prettier": "^2.0.5",
    "request": "^2.88.2",
    "request-promise-native": "^1.0.8",
    "source-map-support": "^0.5.16",
    "ts-jest": "^25.4.0",
    "ts-node": "^8.6.2",
    "typescript": "^3.7.5"
  },
  "dependencies": {
    "aws-sdk": "^2.658.0",
    "gatsby": "^2.31.0",
    "gatsby-image": "^2.4.5",
    "gatsby-plugin-manifest": "^2.4.9",
    "gatsby-plugin-offline": "^3.2.7",
    "gatsby-plugin-react-helmet": "^3.3.2",
    "gatsby-plugin-sharp": "^2.13.0",
    "gatsby-plugin-typescript": "^2.4.6",
    "gatsby-source-apiserver": "^2.0.0",
    "gatsby-source-filesystem": "^2.3.8",
    "gatsby-source-graphql": "^2.13.0",
    "gatsby-source-rest-api": "^0.2.3",
    "gatsby-transformer-sharp": "^2.5.3",
    "moment": "^2.24.0",
    "prop-types": "^15.7.2",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "react-helmet": "^6.0.0"
  }
}
